    </formulas>
    <formulas>
        <name>fResponseBody</name>
        <dataType>String</dataType>
        <expression>&apos;{&quot;success&quot;:&apos; &amp; IF({!vSuccess}, &apos;true&apos;, &apos;false&apos;) &amp; &apos;,&quot;externalRecordId&quot;:&quot;&apos; &amp; {!vExternalRecordId} &amp; &apos;&quot;,&quot;message&quot;:&quot;&apos; &amp; {!vMessage} &amp; &apos;&quot;}&apos;</expression>
