<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>MWD26 Source Access</label>
    <description>Access to the Integration Request object, fields, Apex service, and tab for the MWD26 demo (Source Org).</description>
    <hasActivationRequired>false</hasActivationRequired>
    <classAccesses>
        <apexClass>IntegrationRequestService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <objectPermissions>
        <object>Integration_Request__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>true</allowDelete>
        <viewAllRecords>true</viewAllRecords>
        <modifyAllRecords>true</modifyAllRecords>
    </objectPermissions>
    <fieldPermissions>
        <field>Integration_Request__c.Request_Name__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Integration_Request__c.Customer_Email__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Integration_Request__c.Request_Details__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Integration_Request__c.Status__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Integration_Request__c.External_Record_Id__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Integration_Request__c.Response_Message__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Integration_Request__c.Last_Synced_Date__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <tabSettings>
        <tab>Integration_Request__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
</PermissionSet>
