<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>MWD26 Target Access</label>
    <description>Access to the External Request object, fields, REST class, and tab for the MWD26 demo (Target Org). Assign to the user that authenticates the Named Credential.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <classAccesses>
        <apexClass>BackOfficeRequestResource</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <objectPermissions>
        <object>External_Request__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>true</allowDelete>
        <viewAllRecords>true</viewAllRecords>
        <modifyAllRecords>true</modifyAllRecords>
    </objectPermissions>
    <fieldPermissions>
        <field>External_Request__c.Request_Name__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>External_Request__c.Customer_Email__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>External_Request__c.Request_Details__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>External_Request__c.Source_Record_Id__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>External_Request__c.Source_Org__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>External_Request__c.Processing_Status__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>External_Request__c.Response_Message__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <tabSettings>
        <tab>External_Request__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
</PermissionSet>
